# ─────────────────────────────────────────────────────────────────────────────
# Bid Desk (aerchain) .gitignore
# Monorepo: apps/web (Next.js, pnpm+turbo) · services/ai (Python, uv/FastAPI/LangGraph)
# Goal: keep local deps, build output, caches, and ALL secrets off git + git history.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & credentials (NEVER commit) ────────────────────────────────────
# Every .env variant is ignored; commit a checked-in .env.example instead.
.env
.env.*
*.env
!.env.example
!**/.env.example

# Keys, certs, service-account / credential files
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
secrets.*
*.secret
*credentials*.json
service-account*.json
gcp-*.json
aws-credentials
.npmrc.local

# ── Node / pnpm / JavaScript (apps/web, packages/*) ─────────────────────────
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz

# ── Next.js / web build output ──────────────────────────────────────────────
.next/
out/
build/
dist/
.swc/
*.tsbuildinfo
# next-env.d.ts is committed (Plan 01-01: apps/web workspace link proof)
!apps/web/next-env.d.ts

# ── Turborepo ─────────────────────────────────────────────────────────────--
.turbo/

# ── Deployment (Vercel) ──────────────────────────────────────────────────────
.vercel/

# ── Python (services/ai, uv/FastAPI/LangGraph) ──────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
sdist/
wheels/
*.egg-info/
*.egg
.installed.cfg
MANIFEST

# ── Python virtual environments & dependency caches (uv) ────────────────────
.venv/
venv/
env/
.uv/
.uv-cache/
uv-cache/
pip-wheel-metadata/

# ── Python test / type / lint / coverage caches ─────────────────────────────
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.cache/
nosetests.xml
.hypothesis/

# ── Coverage / test reports (JS) ─────────────────────────────────────────────
coverage/
.nyc_output/

# ── Playwright (E2E — per CLAUDE.md §11) ─────────────────────────────────────
test-results/
playwright-report/
playwright/.cache/
playwright/.auth/
blob-report/
.last-run.json

# ── Logs & runtime ───────────────────────────────────────────────────────────
*.log
logs/
*.pid
*.seed
*.pid.lock

# ── Graphify knowledge-graph build output (regenerable: `graphify update .`) ─
graphify-out/
.planning/graphs/

# ── OS cruft ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# ── Misc local scratch ───────────────────────────────────────────────────────
*.local
tmp/
.tmp/
.cache-loader/
