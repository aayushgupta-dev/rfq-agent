# Bid Desk — required environment variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.

# OpenAI API key — obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model IDs — confirm the exact strings in your OpenAI account.
# Default IDs for the Bid Desk AI service:
MODEL_REASONING=gpt-5.4
MODEL_CHEAP=gpt-5.4-mini
